{
  "name": "amberline-theme",
  "version": "1.0.0",
  "description": "Amberline — Football Club HTML template (black & amber) built with Tailwind CSS",
  "private": true,
  "scripts": {
    "build": "tailwindcss -c tailwind.config.js -i src/input.css -o assets/css/main.css --minify",
    "watch": "tailwindcss -c tailwind.config.js -i src/input.css -o assets/css/main.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
