# Copy to .env (or run `python -m daytrader setup`)

# paper = fake money, real live prices (start here). live = real orders on Coinbase.
MODE=paper

PRODUCTS=BTC-GBP,ETH-GBP
INTERVAL_MINUTES=15
STARTING_CASH_GBP=300

# AI decisions — get a key at https://platform.claude.com
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# Live trading only — CDP API key from https://portal.cdp.coinbase.com
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Safety rails (fractions, not percents: 0.25 = 25%)
MAX_TRADE_PCT=0.25
MIN_CONFIDENCE=0.6
MAX_DAILY_LOSS_PCT=0.05
MAX_TRADES_PER_DAY=12

# Paper-mode realism
FEE_PCT=0.006
SLIPPAGE_PCT=0.0005
MIN_TRADE_GBP=2.0
