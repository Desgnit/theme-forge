<div class="utility-hero">
  <div class="page-width">
    <h1>
      {%- if search.performed -%}
        {{ 'general.search.results_for_html' | t: terms: search.terms | escape }}
      {%- else -%}
        {{ 'general.search.title' | t }}
      {%- endif -%}
    </h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="utility-hero__search">
      <label class="visually-hidden" for="SearchPageInput">{{ 'general.search.title' | t }}</label>
      <input
        type="search"
        id="SearchPageInput"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
      >
      <button type="submit" class="btn btn--primary" aria-label="{{ 'general.search.submit' | t }}">
        {% render 'icon', name: 'search', size: 18 %}
      </button>
    </form>
    {%- if search.performed -%}
      <p class="section__subheading" style="margin: var(--space-4) auto 0;">
        {{ 'general.search.result_count' | t: count: search.results_count }}
      </p>
    {%- endif -%}
  </div>
</div>

{%- if search.performed and search.results_count > 0 -%}
  {%- paginate search.results by section.settings.results_per_page -%}
    <div class="page-width section--tight" style="padding-bottom: var(--space-8);">
      <div class="product-grid" style="--grid-desktop: 4;">
        {%- for item in search.results -%}
          {%- case item.object_type -%}
            {%- when 'product' -%}
              {% render 'product-card', product: item %}
            {%- when 'article' -%}
              <article class="article-card">
                <a class="article-card__media" href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                  {%- if item.image -%}
                    <img
                      src="{{ item.image | image_url: width: 600 }}"
                      alt="{{ item.image.alt | default: item.title | escape }}"
                      width="{{ item.image.width }}"
                      height="{{ item.image.height }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </a>
                <p class="article-card__meta">{{ 'blog.article_label' | t }}</p>
                <h3 class="article-card__title"><a href="{{ item.url }}">{{ item.title | escape }}</a></h3>
              </article>
            {%- when 'page' -%}
              <article class="article-card">
                <p class="article-card__meta">{{ 'general.search.page_label' | t }}</p>
                <h3 class="article-card__title"><a href="{{ item.url }}">{{ item.title | escape }}</a></h3>
                <p class="article-card__excerpt">{{ item.content | strip_html | truncate: 120 }}</p>
              </article>
          {%- endcase -%}
        {%- endfor -%}
      </div>
      {% render 'pagination', paginate: paginate %}
    </div>
  {%- endpaginate -%}
{%- elsif search.performed -%}
  <div class="page-width collection-empty">
    <h2>{{ 'general.search.no_results' | t: terms: search.terms | escape }}</h2>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Search results",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ]
}
{% endschema %}
