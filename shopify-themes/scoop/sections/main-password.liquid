<div class="password-page">
  <span class="section__eyebrow">{{ shop.name | escape }}</span>
  <h1>{{ section.settings.heading | escape }}</h1>
  {%- if section.settings.text != blank -%}
    <p style="max-width: 46ch; opacity: 0.85; margin-top: var(--space-3);">{{ section.settings.text | escape }}</p>
  {%- endif -%}

  <div class="password-page__box">
    {%- form 'customer' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-status form-status--success" role="status" style="justify-content: center;">
          {% render 'icon', name: 'check', size: 16 %}
          {{ 'general.newsletter.success' | t }}
        </p>
      {%- else -%}
        <p style="font-size: var(--text-sm); margin-bottom: var(--space-3);">{{ 'general.password.notify_label' | t }}</p>
        <input type="hidden" name="contact[tags]" value="prospect,password">
        <div style="display: flex; gap: var(--space-2);">
          <label class="visually-hidden" for="PasswordNewsletterEmail">{{ 'general.newsletter.email_label' | t }}</label>
          <input
            type="email"
            name="contact[email]"
            id="PasswordNewsletterEmail"
            placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
            required
            style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.25); color: #fff;"
          >
          <button type="submit" class="btn btn--inverse">{{ 'general.newsletter.submit' | t }}</button>
        </div>
      {%- endif -%}
    {%- endform -%}

    <div style="margin-top: var(--space-5); border-top: 1px solid rgba(255,255,255,0.14); padding-top: var(--space-5);">
      <details>
        <summary style="cursor: pointer; font-size: var(--text-sm);">{{ 'general.password.enter_password' | t }}</summary>
        {%- form 'storefront_password' -%}
          <div style="display: flex; gap: var(--space-2); margin-top: var(--space-3);">
            <label class="visually-hidden" for="StorefrontPassword">{{ 'general.password.password_label' | t }}</label>
            <input
              type="password"
              name="password"
              id="StorefrontPassword"
              placeholder="{{ 'general.password.password_label' | t }}"
              style="background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.25); color: #fff;"
            >
            <button type="submit" class="btn btn--inverse">{{ 'general.password.enter' | t }}</button>
          </div>
          {%- if form.errors -%}
            <p class="form-status form-status--error" role="alert" style="margin-top: var(--space-3);">
              {{ 'general.password.wrong_password' | t }}
            </p>
          {%- endif -%}
        {%- endform -%}
      </details>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Something good is coming"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We're putting the finishing touches on the store. Leave your email and be first through the door."
    }
  ]
}
{% endschema %}
