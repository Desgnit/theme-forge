<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__grid" style="--footer-cols: {{ section.blocks.size | at_least: 1 }};">
      <div class="site-footer__brand">
        <a href="{{ routes.root_url }}" class="site-footer__logo">{{ shop.name }}</a>
        {%- if section.settings.brand_text != blank -%}
          <p>{{ section.settings.brand_text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.show_social -%}
          {%- assign has_social = false -%}
          {%- if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_twitter_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_pinterest_link != blank -%}
            {%- assign has_social = true -%}
          {%- endif -%}
          {%- if has_social -%}
            <div class="site-footer__social">
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" class="btn-icon" aria-label="Instagram">{% render 'icon', name: 'instagram', size: 18 %}</a>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" class="btn-icon" aria-label="Facebook">{% render 'icon', name: 'facebook', size: 18 %}</a>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <a href="{{ settings.social_twitter_link }}" class="btn-icon" aria-label="X (Twitter)">{% render 'icon', name: 'twitter', size: 18 %}</a>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <a href="{{ settings.social_youtube_link }}" class="btn-icon" aria-label="YouTube">{% render 'icon', name: 'youtube', size: 18 %}</a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" class="btn-icon" aria-label="TikTok">{% render 'icon', name: 'tiktok', size: 18 %}</a>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <a href="{{ settings.social_pinterest_link }}" class="btn-icon" aria-label="Pinterest">{% render 'icon', name: 'pinterest', size: 18 %}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="site-footer__column" {{ block.shopify_attributes }}>
              <h2 class="site-footer__heading">{{ block.settings.heading | default: block.settings.menu.title | escape }}</h2>
              <ul class="site-footer__menu">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'newsletter' -%}
            <div class="site-footer__column" {{ block.shopify_attributes }}>
              <h2 class="site-footer__heading">{{ block.settings.heading | escape }}</h2>
              {%- if block.settings.text != blank -%}
                <p style="font-size: var(--text-sm);">{{ block.settings.text | escape }}</p>
              {%- endif -%}
              {%- form 'customer', class: 'site-footer__newsletter' -%}
                {%- if form.posted_successfully? -%}
                  <p class="form-status form-status--success" role="status">
                    {% render 'icon', name: 'check', size: 16 %}
                    {{ 'general.newsletter.success' | t }}
                  </p>
                {%- else -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="site-footer__newsletter-form">
                    <label class="visually-hidden" for="FooterNewsletterEmail">{{ 'general.newsletter.email_label' | t }}</label>
                    <input
                      type="email"
                      name="contact[email]"
                      id="FooterNewsletterEmail"
                      placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
                      required
                      autocomplete="email"
                    >
                    <button type="submit" class="btn btn--inverse" aria-label="{{ 'general.newsletter.submit' | t }}">
                      {% render 'icon', name: 'arrow-right', size: 18 %}
                    </button>
                  </div>
                {%- endif -%}
              {%- endform -%}
            </div>
          {%- when 'text' -%}
            <div class="site-footer__column" {{ block.shopify_attributes }}>
              <h2 class="site-footer__heading">{{ block.settings.heading | escape }}</h2>
              <div style="font-size: var(--text-sm);">{{ block.settings.text }}</div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <p style="margin: 0;">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.footer.rights' | t }}</p>
      {%- if section.settings.show_payment_icons -%}
        <div class="payment-icons" role="list" aria-label="{{ 'general.footer.payment_methods' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            <span role="listitem">{{ type | payment_type_svg_tag: class: 'payment-icon' }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "shopify-section-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand tagline",
      "default": "Built to convert. Designed to last."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "info": "Set your links under Theme settings > Social media.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay in the loop"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New drops, restocks and subscriber-only offers."
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Tell customers where you ship from, your support hours, or anything else worth knowing.</p>"
        }
      ]
    }
  ]
}
{% endschema %}
