<section class="section section--tight promo-tiles">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section__header">
        <h2 class="section__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}
    <div class="promo-tiles__grid" style="--tiles-count: {{ section.blocks.size | at_least: 1 | at_most: 4 }};">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="promo-tile{% if section.settings.tall_tiles %} promo-tile--tall{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w"
              sizes="(min-width: 750px) 33vw, 100vw"
              alt="{{ block.settings.image.alt | default: block.settings.heading | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
            >
          {%- endif -%}
          <span class="promo-tile__caption">
            {%- if block.settings.heading != blank -%}
              <h3>{{ block.settings.heading | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p>{{ block.settings.text | escape }}</p>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <span class="promo-tile__cta">
                {{ block.settings.cta_label | escape }}
                {% render 'icon', name: 'arrow-right', size: 14 %}
              </span>
            {%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo tiles",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "tall_tiles",
      "label": "Taller tiles",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop the range"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Link label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo tiles",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
