<section class="section faq">
  <div class="page-width">
    <div class="section__header" style="justify-content: center; text-align: center;">
      <div style="margin-inline: auto;">
        {%- if section.settings.eyebrow != blank -%}
          <span class="section__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        <h2 class="section__heading">{{ section.settings.heading | escape }}</h2>
      </div>
    </div>
    <div class="faq__list">
      {%- for block in section.blocks -%}
        <details class="faq__item" {{ block.shopify_attributes }}{% if forloop.first and section.settings.open_first %} open{% endif %}>
          <summary>
            {{ block.settings.question | escape }}
            {% render 'icon', name: 'plus', size: 18 %}
          </summary>
          <div class="faq__answer rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open the first question by default",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Most orders leave our warehouse within 24 hours and arrive in 2–5 business days, depending on your location.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question", "settings": { "question": "What is your return policy?", "answer": "<p>You have 30 days from delivery to return any unused item for a full refund. Returns are free.</p>" } },
        { "type": "question", "settings": { "question": "Do you ship internationally?", "answer": "<p>Yes — we ship to most countries worldwide. Duties and taxes are calculated at checkout where applicable.</p>" } }
      ]
    }
  ]
}
{% endschema %}
