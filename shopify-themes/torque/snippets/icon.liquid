{% comment %}
  Inline SVG icons by handle.
  Usage: {% render 'icon', name: 'cart', size: 20 %}
{% endcomment %}
{%- liquid
  assign size = size | default: 20
-%}
{%- case name -%}
  {%- when 'cart' -%}
    <svg class="icon icon-cart" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M5.5 8h13l-.9 11a1.5 1.5 0 0 1-1.5 1.4H7.9A1.5 1.5 0 0 1 6.4 19L5.5 8Z"/><path d="M8.8 10V6.4a3.2 3.2 0 0 1 6.4 0V10"/></svg>
  {%- when 'search' -%}
    <svg class="icon icon-search" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true" focusable="false"><circle cx="10.5" cy="10.5" r="6.5"/><path d="m20 20-4.8-4.8"/></svg>
  {%- when 'menu' -%}
    <svg class="icon icon-menu" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true" focusable="false"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
