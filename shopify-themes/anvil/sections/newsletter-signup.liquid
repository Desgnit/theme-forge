<section class="section newsletter">
  <div class="page-width">
    <div class="newsletter__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="section__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="section__subheading" style="margin-inline: auto;">{{ section.settings.text | escape }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter__signup' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-status form-status--success" role="status" style="justify-content: center;">
            {% render 'icon', name: 'check', size: 16 %}
            {{ 'general.newsletter.success' | t }}
          </p>
        {%- else -%}
          {%- if form.errors -%}
            <p class="form-status form-status--error" role="alert" style="justify-content: center;">
              {% render 'icon', name: 'error', size: 16 %}
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </p>
          {%- endif -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter__form">
            <label class="visually-hidden" for="NewsletterSectionEmail-{{ section.id }}">{{ 'general.newsletter.email_label' | t }}</label>
            <input
              type="email"
              name="contact[email]"
              id="NewsletterSectionEmail-{{ section.id }}"
              placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
              required
              autocomplete="email"
            >
            <button type="submit" class="btn btn--primary">{{ 'general.newsletter.submit' | t }}</button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Join the list for early access to drops, restocks and subscriber-only offers. No spam, ever."
    }
  ],
  "presets": [
    {
      "name": "Newsletter signup"
    }
  ]
}
{% endschema %}
