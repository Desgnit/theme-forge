{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar" role="region" aria-label="{{ 'sections.announcement.label' | t }}">
    <div class="page-width">
      {%- for block in section.blocks -%}
        <div class="announcement-bar__inner" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {%- else -%}
            <p>{{ block.settings.text | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "shopify-section-announcement",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over $75 — no code needed"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [{ "type": "announcement" }]
    }
  ]
}
{% endschema %}
