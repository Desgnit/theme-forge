<section class="section section--tight logo-list">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="section__eyebrow" style="display: block; text-align: center; margin-bottom: var(--space-5);">
        {{ section.settings.heading | escape }}
      </p>
    {%- endif -%}
    <div class="logo-list__row">
      {%- for block in section.blocks -%}
        <div class="logo-list__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 300 }}"
              alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
            >
          {%- else -%}
            <span class="logo-list__text">{{ block.settings.label | escape }}</span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Logo list",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As featured in"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Text fallback",
          "info": "Shown if no image is set.",
          "default": "PressName"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo list",
      "blocks": [
        { "type": "logo", "settings": { "label": "Journal" } },
        { "type": "logo", "settings": { "label": "The Standard" } },
        { "type": "logo", "settings": { "label": "Makers Weekly" } },
        { "type": "logo", "settings": { "label": "Field Notes" } }
      ]
    }
  ]
}
{% endschema %}
