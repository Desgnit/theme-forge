<section class="section countdown-banner">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <span class="section__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}
    <h2 class="countdown-banner__heading">{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.text != blank -%}
      <p class="countdown-banner__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.deadline != blank -%}
      <div
        class="countdown"
        data-countdown
        data-deadline="{{ section.settings.deadline | escape }}"
        role="timer"
        aria-label="{{ 'sections.countdown.label' | t }}"
      >
        <div class="countdown__unit">
          <span class="countdown__value" data-countdown-days>00</span>
          <span class="countdown__label">{{ 'general.countdown.days' | t }}</span>
        </div>
        <div class="countdown__unit">
          <span class="countdown__value" data-countdown-hours>00</span>
          <span class="countdown__label">{{ 'general.countdown.hours' | t }}</span>
        </div>
        <div class="countdown__unit">
          <span class="countdown__value" data-countdown-minutes>00</span>
          <span class="countdown__label">{{ 'general.countdown.minutes' | t }}</span>
        </div>
        <div class="countdown__unit">
          <span class="countdown__value" data-countdown-seconds>00</span>
          <span class="countdown__label">{{ 'general.countdown.seconds' | t }}</span>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link }}" class="btn btn--inverse btn--large">{{ section.settings.cta_label | escape }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Countdown banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Limited time"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The mid-season sale ends soon"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Up to 40% off selected lines. When it's gone, it's gone."
    },
    {
      "type": "text",
      "id": "deadline",
      "label": "Deadline",
      "info": "Format: YYYY-MM-DDTHH:MM (visitor's local time), e.g. 2026-12-31T23:59",
      "default": "2026-12-31T23:59"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the sale"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Countdown banner"
    }
  ]
}
{% endschema %}
