<div class="utility-hero">
  <div class="page-width">
    <p class="error-code" aria-hidden="true">404</p>
    <h1>{{ 'general.404.title' | t }}</h1>
    <p class="section__subheading" style="margin: var(--space-3) auto 0;">{{ 'general.404.subtext' | t }}</p>
    <div style="margin-top: var(--space-6); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
      <a href="{{ routes.root_url }}" class="btn btn--primary btn--large">{{ 'general.404.home_link' | t }}</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary btn--large">{{ 'general.404.shop_link' | t }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404 page",
  "settings": []
}
{% endschema %}
