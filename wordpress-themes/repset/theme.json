{
	"$schema": "https://schemas.wp.org/wp/6.5/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1240px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "charcoal", "color": "#131313", "name": "Charcoal" },
				{ "slug": "asphalt", "color": "#1c1c1c", "name": "Asphalt" },
				{ "slug": "steel", "color": "#262626", "name": "Steel" },
				{ "slug": "crimson", "color": "#e02424", "name": "Crimson" },
				{ "slug": "crimson-deep", "color": "#b31b1b", "name": "Deep Crimson" },
				{ "slug": "concrete", "color": "#8a8a8a", "name": "Concrete" },
				{ "slug": "chalk", "color": "#d6d6d6", "name": "Chalk" },
				{ "slug": "white", "color": "#ffffff", "name": "White" }
			],
			"gradients": [
				{
					"slug": "charcoal-fade",
					"gradient": "linear-gradient(180deg, rgba(19,19,19,0) 0%, #131313 100%)",
					"name": "Charcoal Fade"
				},
				{
					"slug": "crimson-punch",
					"gradient": "linear-gradient(135deg, #e02424 0%, #8f1414 100%)",
					"name": "Crimson Punch"
				},
				{
					"slug": "poster-overlay",
					"gradient": "linear-gradient(180deg, rgba(19,19,19,0.55) 0%, rgba(19,19,19,0.85) 100%)",
					"name": "Poster Overlay"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Oswald (Display)",
					"fontFamily": "'Oswald', 'Arial Narrow', 'Helvetica Neue', sans-serif"
				},
				{
					"slug": "body",
					"name": "Inter (Body)",
					"fontFamily": "'Inter', 'Helvetica Neue', Arial, sans-serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": false
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.0625rem",
					"fluid": false
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.375rem",
					"fluid": { "min": "1.25rem", "max": "1.5rem" }
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "2rem",
					"fluid": { "min": "1.65rem", "max": "2.25rem" }
				},
				{
					"slug": "xx-large",
					"name": "Heading XXL",
					"size": "3rem",
					"fluid": { "min": "2.25rem", "max": "3.5rem" }
				},
				{
					"slug": "display",
					"name": "Display",
					"size": "4.5rem",
					"fluid": { "min": "3rem", "max": "5.5rem" }
				},
				{
					"slug": "colossal",
					"name": "Colossal",
					"size": "6.5rem",
					"fluid": { "min": "3.75rem", "max": "8rem" }
				}
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "20", "size": "0.5rem", "name": "2X-Small" },
				{ "slug": "30", "size": "1rem", "name": "X-Small" },
				{ "slug": "40", "size": "1.5rem", "name": "Small" },
				{ "slug": "50", "size": "clamp(1.75rem, 4vw, 2.5rem)", "name": "Medium" },
				{ "slug": "60", "size": "clamp(2.5rem, 6vw, 4rem)", "name": "Large" },
				{ "slug": "70", "size": "clamp(3.5rem, 8vw, 6rem)", "name": "X-Large" },
				{ "slug": "80", "size": "clamp(5rem, 10vw, 8rem)", "name": "2X-Large" }
			]
		},
		"custom": {
			"lineHeight": {
				"tight": 1.05,
				"heading": 1.15,
				"body": 1.65
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--charcoal)",
			"text": "var(--wp--preset--color--white)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"fontWeight": "400",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.01em",
					"lineHeight": "1.15"
				},
				"color": {
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--display)",
					"fontWeight": "700",
					"lineHeight": "1.05"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "700",
					"lineHeight": "1.1"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--white)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--crimson)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--crimson)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.12em"
				},
				"border": {
					"radius": "0px"
				},
				"spacing": {
					"padding": {
						"top": "0.9rem",
						"bottom": "0.9rem",
						"left": "2rem",
						"right": "2rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--crimson-deep)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--concrete)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "500",
					"textTransform": "uppercase",
					"letterSpacing": "0.14em",
					"fontSize": "0.9375rem"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--crimson)",
						"style": "solid",
						"width": "4px"
					}
				},
				"spacing": {
					"padding": {
						"left": "1.5rem"
					}
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--steel)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontWeight": "700"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"textTransform": "uppercase"
				},
				"border": {
					"top": {
						"color": "var(--wp--preset--color--crimson)",
						"style": "solid",
						"width": "4px"
					},
					"bottom": {
						"color": "var(--wp--preset--color--crimson)",
						"style": "solid",
						"width": "4px"
					}
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": []
}
